import { VerticalBox } from "std-widgets.slint";
import { UrlBar } from "components/url_bar.slint";
import { RequestPanel } from "components/request_panel.slint";
import { ResponsePanel } from "components/response_panel.slint";

export component MainWindow inherits Window {
    title: "Requestman";
    width: 900px;
    height: 700px;
    background: #ffffff;

    VerticalBox {
        spacing: 0px;
        padding: 0px;

        UrlBar {}

        RequestPanel {
            vertical-stretch: 1;
        }

        Rectangle {
            height: 2px;
            background: #e0e0e0;
        }

        ResponsePanel {
            vertical-stretch: 1;
        }
    }
}
