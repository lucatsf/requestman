import { VerticalBox, HorizontalBox } from "std-widgets.slint";
import { UrlBar } from "components/url_bar.slint";
import { RequestPanel } from "components/request_panel.slint";
import { ResponsePanel } from "components/response_panel.slint";
import { Sidebar, CollectionItem } from "components/sidebar.slint";

export component MainWindow inherits Window {
    title: "Requestman";
    width: 900px;
    height: 700px;

    in-out property <string> url <=> url-bar.url;
    in-out property <string> method <=> url-bar.current-method;
    in-out property <string> request-body <=> request-panel.body-text;
    in-out property <string> header1-key <=> request-panel.header1-key;
    in-out property <string> header1-val <=> request-panel.header1-val;
    in-out property <string> header2-key <=> request-panel.header2-key;
    in-out property <string> header2-val <=> request-panel.header2-val;

    in-out property <string> param1-key <=> request-panel.param1-key;
    in-out property <string> param1-val <=> request-panel.param1-val;
    in-out property <string> param2-key <=> request-panel.param2-key;
    in-out property <string> param2-val <=> request-panel.param2-val;

    in-out property <string> response-body <=> response-panel.response-body;
    in property <[string]> response-lines <=> response-panel.response-lines;
    in-out property <string> response-status <=> response-panel.status;
    in-out property <string> response-time <=> response-panel.time;
    in-out property <string> response-size <=> response-panel.size;

    in property <[CollectionItem]> collection-items;

    callback send-request();
    callback save-request(string);
    callback load-request(int);
    callback copy-response();

    property <length> request-height: 250px;

    HorizontalBox {
        spacing: 0px;
        padding: 0px;

        Sidebar {
            items: root.collection-items;
            item-clicked(idx) => { root.load-request(idx) }
        }

        VerticalBox {
            spacing: 0px;
            padding: 0px;

            url-bar := UrlBar {
                on-send => { root.send-request() }
                on-save => { 
                    root.save-request(root.url == "" ? "Nova Requisição" : root.url) 
                }
            }

            request-panel := RequestPanel {
                height: root.request-height;
            }

            Rectangle {
                height: 4px;
                background: touch.has-hover || touch.pressed ? #f26b3a : #888888;
                opacity: touch.has-hover || touch.pressed ? 1.0 : 0.3;

                touch := TouchArea {
                    mouse-cursor: row-resize;
                    moved => {
                        root.request-height = max(100px, root.request-height + self.mouse-y);
                    }
                }
            }

            response-panel := ResponsePanel {
                vertical-stretch: 1;
                copy-clicked => { root.copy-response() }
            }
        }
    }
}
