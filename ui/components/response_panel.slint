import { TextEdit, VerticalBox, HorizontalBox, ListView } from "std-widgets.slint";
import { CustomTab } from "shared.slint";

export component ResponsePanel inherits VerticalBox {
    in-out property <string> active-tab: "Body";
    in-out property <string> response-body: "Aguardando requisição...";
    in property <[string]> response-lines;
    in property <string> status: "200 OK";
    in property <string> time: "0 ms";
    in property <string> size: "0 B";
    
    callback copy-clicked();
    
    spacing: 0px;
    padding: 10px;

    HorizontalBox {
        alignment: space-between;
        
        HorizontalBox {
            alignment: start;
            spacing: 10px;
            CustomTab { text: "Body"; active: active-tab == "Body"; clicked => { active-tab = "Body" } }
            CustomTab { text: "Cookies"; active: active-tab == "Cookies"; clicked => { active-tab = "Cookies" } }
            CustomTab { text: "Headers"; active: active-tab == "Headers"; clicked => { active-tab = "Headers" } }
        }
        
        HorizontalBox {
            alignment: end;
            spacing: 15px;
            
            // Botão de copiar adicionado
            Rectangle {
                width: 60px;
                height: 25px;
                background: touch-copy.has-hover ? #f26b3a : #444;
                border-radius: 4px;
                Text { text: "Copiar"; color: white; horizontal-alignment: center; vertical-alignment: center; font-size: 12px; font-weight: 700; }
                touch-copy := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.copy-clicked() }
                }
            }
            
            Text { text: root.status; color: #2e8b57; vertical-alignment: center; font-weight: 700; }
            Text { text: root.time; color: #2e8b57; vertical-alignment: center; font-weight: 700; }
            Text { text: root.size; color: #2e8b57; vertical-alignment: center; font-weight: 700; }
        }
    }
    
    Rectangle {
        height: 1px;
        background: #888888;
        opacity: 0.3;
    }
    Rectangle { height: 10px; }

    VerticalBox {
        visible: active-tab == "Body";
        Rectangle {
            background: #1e1e1e; // Fundo escuro de editor de código
            border-radius: 5px;
            VerticalLayout {
                padding: 15px;
                ListView {
                    for line in root.response-lines: HorizontalLayout {
                        padding-top: 1px;
                        padding-bottom: 1px;
                        Text {
                            text: line;
                            color: #9cdcfe; // Azul claro típico de chaves JSON em temas dark
                            font-family: "Courier New";
                            font-size: 14px;
                            wrap: word-wrap;
                        }
                    }
                }
            }
        }
    }
    
    if active-tab != "Body" : VerticalBox {
        Text { text: "Visualização não implementada."; color: #888; }
    }
}
